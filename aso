# Commands
# --------------------------------------------------------------------------- #

def _autosuggest_signal(keyword: str, country: str) -> tuple[int | None, str]:
    """Cross-check estimated popularity against Apple's own autosuggest.

    If typing the exact keyword surfaces it in Apple's suggestions,
    real users search it (Apple only suggests actual search terms).
    Returns (1-based rank in suggestions or None, confidence label).
    """
    kw = keyword.lower().strip()
    kw_words = set(kw.split())
    try:
        terms = [t.lower().strip() for t in suggestions(kw, country)]
    except Exception:
        return None, "unknown"
    if kw in terms:
        return terms.index(kw) + 1, "high"
    if any(kw_words <= set(t.split()) for t in terms):
        return None, "medium"
    return None, "low"


def analyze_keyword(keyword: str, country: str, with_apps: bool = False) -> dict:
    apps = search_apps(keyword, country)
    pop = popularity_score(apps, keyword)
    diff, breakdown = difficulty_score(apps, keyword)
    suggest_rank, confidence = _autosuggest_signal(keyword, country)
    result = {
        "keyword": keyword,
        "country": country,
        "popularity": pop,
        "difficulty": diff,
        "opportunity": opportunity_score(pop, diff),
        "classification": classify(pop, diff),
        "est_daily_searches": int(_daily_searches(pop)) if pop else 0,
        "result_count": len(apps),
        "autosuggest_rank": suggest_rank,
        "popularity_confidence": confidence,
        "difficulty_breakdown": breakdown,
    }
    if with_apps:
        result["top_apps"] = [
            {k: a[k] for k in ("id", "title", "seller", "ratings", "stars", "released")}
            for a in apps[:10]
        ]
    return result


def cmd_score(args) -> dict:
    results = []
    for i, kw in enumerate(args.keywords):
        print(f"[{i + 1}/{len(args.keywords)}] scoring '{kw}'...", file=sys.stderr)
        results.append(analyze_keyword(kw, args.country, with_apps=args.apps))
    results.sort(key=lambda r: -r["opportunity"])
    return {"keywords": results} if len(results) > 1 else results[0]


def cmd_suggest(args) -> dict:
    terms = suggestions(args.term, args.country)
    return {"term": args.term, "country": args.country, "suggestions": terms}


def cmd_search(args) -> dict:
    apps = search_apps(args.term, args.country, limit=args.limit)
    return {"term": args.term, "country": args.country,
            "result_count": len(apps), "apps": apps}


def cmd_research(args) -> dict:
    """Expand a seed via Apple autosuggest, score every candidate,
    rank by opportunity. This is the underserved-keyword finder."""
    seeds = [args.seed.strip().lower()]
    candidates: list[str] = []
    seen: set[str] = set()

    def add(terms):
        for t in terms:
            t = t.strip().lower()
            if t and t not in seen:
                seen.add(t)
                candidates.append(t)

    add(seeds)
    print(f"expanding '{args.seed}' via App Store autosuggest...", file=sys.stderr)
    add(suggestions(args.seed, args.country))
    if args.deep:
        for ch in "abcdefghijklmnopqrstuvwxyz":
            add(suggestions(f"{args.seed} {ch}", args.country))
        # second hop: suggestions of the first-round suggestions
        for t in list(candidates)[1:12]:
            add(suggestions(t, args.country))

    candidates = candidates[: args.limit]
    print(f"scoring {len(candidates)} keywords "
          f"(~{int(len(candidates) * _RATE['search'])}s uncached)...", file=sys.stderr)
    results = []
    for i, kw in enumerate(candidates):
        print(f"[{i + 1}/{len(candidates)}] {kw}", file=sys.stderr)
        try:
            results.append(analyze_keyword(kw, args.country))
        except Exception as e:
            print(f"  skipped ({e})", file=sys.stderr)

    results.sort(key=lambda r: -r["opportunity"])
    for r in results:
        r.pop("difficulty_breakdown", None)
    return {
        "seed": args.seed,
        "country": args.country,
        "scored": len(results),
        "underserved": [r for r in results
                        if r["classification"] in ("Sweet Spot", "Hidden Gem", "Good Target")],
        "all": results,
    }


def cmd_rank(args) -> dict:
    """Where an app ranks in real App Store search for each keyword."""
    out = []
    for kw in args.keywords:
        print(f"checking rank for '{kw}'...", file=sys.stderr)
        ids = ssr_ranking(kw, args.country)
        rank = ids.index(args.app_id) + 1 if args.app_id in ids else None
        out.append({"keyword": kw, "rank": rank, "results_checked": len(ids)})
    return {"app_id": args.app_id, "country": args.country, "ranks": out}


INTERPRETATION = """\
how to read the numbers:
  popularity   5-100   estimated search demand. relative ordering is reliable;
                       absolute values are estimates (nobody outside Apple has
                       real per-keyword search counts).
  difficulty   1-100   how hard it is to rank top-10 if you target the exact
                       phrase in your title/subtitle. <30 easy, 30-50 doable,
                       50-65 needs traction, >65 dominated by established apps.
  opportunity  0-100   popularity gated by difficulty. sort by this.
  classification       Sweet Spot / Hidden Gem / Good Target = worth targeting.
                       High Competition / Low Volume / Avoid = skip.
  popularity_confidence  high = the term appears in Apple's own autosuggest
                       (real users type it). low = popularity may be inflated
                       by Apple backfilling results with big apps from broader
                       terms; trust difficulty, distrust popularity.

typical workflow:
  aso research "your niche"            find candidate keywords, sorted
  aso score "kw1" "kw2" --apps         deep-dive finalists, see competitors
  aso rank <app_id> "kw1" "kw2"        baseline your current ranks
  (ship metadata, wait for reindex, re-run rank to measure)
"""


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="aso",
        description="App Store keyword research from public Apple endpoints: "
                    "popularity, difficulty, and opportunity scores per keyword. "
                    "No accounts, no API keys. JSON on stdout, progress on stderr.",
        epilog=INTERPRETATION,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--country", default="us",
                        help="two-letter storefront code: us, gb, de, jp... (default: us)")
    parser.add_argument("--fresh", action="store_true",
                        help="bypass the 24h response cache and refetch")
    parser.add_argument("--version", action="version", version=f"aso-cli {__version__}")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser(
        "score",
        help="score one or more keywords (popularity, difficulty, opportunity)",
        description="Score keywords. One iTunes search + one autosuggest call per "
                    "keyword. Multiple keywords are returned sorted by opportunity.",
    )
    p.add_argument("keywords", nargs="+")
    p.add_argument("--apps", action="store_true",
                   help="include the top 10 competing apps per keyword")
    p.set_defaults(fn=cmd_score)

    p = sub.add_parser(
        "suggest",
        help="Apple's autosuggest completions for a term",
        description="What the App Store search box suggests while typing this term, "
                    "in Apple's own popularity order. Only real user search terms "
                    "appear here, which makes it both a keyword source and a "
                    "demand check.",
    )
    p.add_argument("term")
    p.set_defaults(fn=cmd_suggest)

    p = sub.add_parser(
        "search",
        help="top App Store results for a term (raw competitor data)",
        description="The apps competing for a term, with ratings, stars, release "
                    "dates, and sellers. This is the raw input the scores are "
                    "computed from.",
    )
    p.add_argument("term")
    p.add_argument("--limit", type=int, default=25, help="max apps (default: 25)")
    p.set_defaults(fn=cmd_search)

    p = sub.add_parser(
        "research",
        help="expand a seed keyword via autosuggest and rank all candidates",
        description="The main workflow: expands a seed through Apple autosuggest, "
                    "scores every candidate, and returns them sorted by opportunity. "
                    "Keywords classified Sweet Spot / Hidden Gem / Good Target are "
                    "also collected in the 'underserved' array.",
    )
    p.add_argument("seed")
    p.add_argument("--limit", type=int, default=30,
                   help="max keywords to score (default: 30)")
    p.add_argument("--deep", action="store_true",
                   help="also expand 'seed a'..'seed z' and second-hop suggestions "
                        "(finds long-tail, much slower)")
    p.set_defaults(fn=cmd_research)

    p = sub.add_parser(
        "rank",
        help="an app's real App Store search rank for keywords",
        description="Where an app appears in actual App Store search results "
                    "(scraped from the App Store web page, which mirrors device "
                    "ranking). Use before and after a metadata change to measure "
                    "movement. Find an app's numeric id in its App Store URL or "
                    "via 'aso search'.",
    )
    p.add_argument("app_id", type=int, help="numeric App Store id (trackId)")
    p.add_argument("keywords", nargs="+")
    p.set_defaults(fn=cmd_rank)

    args = parser.parse_args()
    global FRESH
    FRESH = args.fresh
    try:
        result = args.fn(args)
    except urllib.error.HTTPError as e:
        print(f"aso: Apple endpoint returned HTTP {e.code} for {e.url}", file=sys.stderr)
        if e.code in (403, 429):
            print("aso: likely rate-limited; wait a minute and retry "
                  "(cached results are unaffected)", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"aso: network error: {e.reason}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        sys.exit(130)
    json.dump(result, sys.stdout, indent=2, ensure_ascii=False)
    print()


if __name__ == "__main__":
    main()
